# =========================================================================
# Lumofy Signals — environment variables
#
# Copy this file to `.env.local` and fill in the values you have.
# The app runs in SAMPLE MODE when DATABASE_URL and the integration tokens
# are absent — it serves realistic seeded data so you can build/preview the
# UI before wiring real services. Add credentials below to go live.
# =========================================================================

# ---- App ----------------------------------------------------------------
# Public base URL of the app (used for links in reports, webhooks, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Auth: Clerk --------------------------------------------------------
# https://dashboard.clerk.com  → API Keys
# When BOTH keys are absent, auth is bypassed (dev/sample mode).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Restrict sign-ups to your domain in the Clerk dashboard (Restrictions → Allowlist).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-in"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ---- Database: Supabase Postgres ----------------------------------------
# Supabase → Project Settings → Database → Connection string.
# Use the "Connection pooling" (Transaction, port 6543) string for the app,
# and the "Direct connection" (port 5432) string for migrations.
# When DATABASE_URL is empty, the app falls back to the in-memory sample store.
DATABASE_URL=""
DIRECT_DATABASE_URL=""

# ---- Integration: HubSpot ----------------------------------------------
# HubSpot is acquisition-only: it surfaces Closed Won deals in the Direct &
# Indirect Sales pipelines and their associated companies, contacts, and
# attachments. Renewals/expansions are managed in-app (not read from HubSpot).
# Create a Private App with scopes: crm.objects.deals.read,
# crm.objects.companies.read, crm.objects.contacts.read,
# crm.objects.owners.read, and files (to resolve deal attachments).
HUBSPOT_ACCESS_TOKEN=""
# HubSpot portal id (for building record links). Optional.
HUBSPOT_PORTAL_ID=""

# ---- Integration: Intercom ----------------------------------------------
# Intercom → Settings → Developers → Developer Hub → your app → Access Token.
INTERCOM_ACCESS_TOKEN=""
# Region: "us" (api.intercom.io), "eu" (api.eu.intercom.io), or "au".
INTERCOM_REGION="us"

# ---- Integration: Metabase ----------------------------------------------
# Metabase base URL, e.g. https://metabase.yourco.com
METABASE_URL=""
# Recommended: a Metabase API key (Admin → Settings → API Keys).
METABASE_API_KEY=""
# Alternatively, username/password session auth (less preferred).
METABASE_USERNAME=""
METABASE_PASSWORD=""
# The Metabase question/card id (or saved SQL) that returns per-account usage.
METABASE_USAGE_CARD_ID=""

# ---- Sync ---------------------------------------------------------------
# Shared secret to protect the /api/sync endpoint (cron / manual trigger).
SYNC_SECRET=""
